
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  email           String         @unique
  first_name      String
  last_name       String
  full_name        String
  passwordHash    String
  role            UserRole       @default(USER)
  isEmailVerified Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

 
  avatarUrl       String?
  resetToken          String?
  resetTokenExpiresAt DateTime?

  // Relations
  refreshTokens   RefreshToken[]
  member     Member[]
  createdWorkspaces Workspace[]  @relation("WorkspaceOwners")
  createdProjects   Project[]    @relation("ProjectOwners")
  createdTasks      Task[]       @relation("TaskCreators")
}

model RefreshToken {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  token        String   @unique              // @unique already creates an index
  userId       String   @db.ObjectId
  user         User     @relation(fields: [userId], references: [id])
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  replacedById String?  @db.ObjectId
  revoked      Boolean  @default(false)
  revokedAt    DateTime?

  @@index([userId])    
}

model Workspace {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  profilePic   String?
  createdAt DateTime   @default(now())

  // Relations
  ownerId   String     @db.ObjectId
  owner     User       @relation("WorkspaceOwners", fields: [ownerId], references: [id])
  projects  Project[]
  members   Member[]
  invites     Invite[]    @relation("WorkspaceInvites")
}

model Project {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  profilePic  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  workspaceId String     @db.ObjectId
  workspace   Workspace  @relation(fields: [workspaceId], references: [id])

  ownerId     String     @db.ObjectId
  owner       User       @relation("ProjectOwners", fields: [ownerId], references: [id])

  tasks       Task[]
  members     Member[]
  invites     Invite[]    @relation("ProjectInvites") 
}


model TaskAssignment {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  taskId   String @db.ObjectId
  memberId String @db.ObjectId

  task   Task   @relation(fields: [taskId], references: [id])
  member Member @relation(fields: [memberId], references: [id])

  @@unique([taskId, memberId])
}


model Task {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  task_name       String
  description String?
  status      TaskStatus   @default(BACKLOG)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  projectId   String       @db.ObjectId
  project     Project      @relation(fields: [projectId], references: [id])

  createdById String       @db.ObjectId
  createdBy   User         @relation("TaskCreators", fields: [createdById], references: [id])

  assignments TaskAssignment[]
}

model Member {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  userId      String      @db.ObjectId
  user        User        @relation(fields: [userId], references: [id])
  role        MemberRole  @default(CONTRIBUTOR)
  joinedAt    DateTime    @default(now())

  workspaceId String?     @db.ObjectId
  workspace   Workspace?  @relation(fields: [workspaceId], references: [id])

  projectId   String?     @db.ObjectId
  project     Project?    @relation(fields: [projectId], references: [id])

  assignments TaskAssignment[]

}

model Invite {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  email       String
  role        String
  workspaceId String?    @db.ObjectId
  projectId   String?    @db.ObjectId
  token       String     @unique
  expiresAt   DateTime
  createdAt   DateTime   @default(now())
  createdById String     @db.ObjectId
  
  
  workspace   Workspace? @relation("WorkspaceInvites", fields: [workspaceId], references: [id])
  project     Project?   @relation("ProjectInvites", fields: [projectId], references: [id])
}








enum UserRole {
  ADMIN
  USER
  MANAGER
}


enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  IN_REVIEW
  TODO
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MemberRole {
  OWNER
  CONTRIBUTOR
  VIEWER
}